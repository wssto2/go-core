{
  "title": "go-core-example — Error Tracking",
  "uid": "go-core-errors",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total 5xx Errors (last 5 min)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(increase(go_core_http_errors_total[5m])) or vector(0)",
          "legendFormat": "5xx errors"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate (errors / total req)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] }, "unit": "percentunit" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(go_core_http_errors_total[5m])) / sum(rate(go_core_http_requests_total[5m])) or vector(0)",
          "legendFormat": "error rate"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Requests (last 5 min)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(increase(go_core_http_requests_total[5m])) or vector(0)",
          "legendFormat": "requests"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "p99 Latency",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum(rate(go_core_http_request_duration_seconds_bucket[5m])) by (le)) or vector(0)",
          "legendFormat": "p99"
        }
      ]
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Error Rate by Endpoint",
      "description": "Rate of 5xx responses per endpoint over time. Spikes indicate broken handlers or DB failures.",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (method, path) (rate(go_core_http_errors_total[1m]))",
          "legendFormat": "{{method}} {{path}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Request Duration Percentiles (all endpoints)",
      "description": "p50 / p95 / p99 latency. High p99 with low error rate = slow queries, not crashes.",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum(rate(go_core_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(go_core_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum(rate(go_core_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Errors by HTTP Status Code",
      "description": "Breakdown of 5xx errors by status. 500 = unhandled panic / DB error. 503 = circuit breaker open.",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (status) (rate(go_core_http_errors_total[1m]))",
          "legendFormat": "HTTP {{status}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Request Throughput by Endpoint",
      "description": "Requests per second per route. Use this to correlate errors with traffic spikes.",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (method, path) (rate(go_core_http_requests_total[1m]))",
          "legendFormat": "{{method}} {{path}}"
        }
      ]
    },

    {
      "id": 9,
      "type": "table",
      "title": "Error Leaderboard — Top Failing Endpoints",
      "description": "Ranked by total errors in the selected time window.",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "options": { "sortBy": [{ "displayName": "Errors", "desc": true }] },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Errors" },
            "properties": [
              { "id": "custom.width", "value": 120 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }] } },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sort_desc(sum by (method, path, status) (increase(go_core_http_errors_total[$__range])))",
          "legendFormat": "{{method}} {{path}} {{status}}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "renameByName": { "Value": "Errors", "method": "Method", "path": "Path", "status": "Status" } } }
      ]
    }
  ]
}
